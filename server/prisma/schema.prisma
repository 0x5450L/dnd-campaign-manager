generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String           @id @default(uuid())
  email        String           @unique
  passwordHash String           @map("password_hash")
  displayName  String           @map("display_name")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  memberships  CampaignMember[] @relation("UsersCampaigns")
  dmCampaigns  Campaign[]       @relation("CampaignDM")
  characters   Character[]      @relation("UserCharacters")

  @@map("users")
}

model Campaign {
  id          String   @id @default(uuid())
  name        String
  description String?
  setting     String?
  imageUrl    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  dmId        String

  dm         User             @relation("CampaignDM", fields: [dmId], references: [id])
  members    CampaignMember[] @relation("CampaignMembership")
  invites    CampaignInvite[] @relation("CampaignInvites")
  characters Character[]      @relation("CampaignCharacters")

  @@unique([dmId, name])
  @@map("campaigns")
}

model CampaignMember {
  id         String   @id @default(uuid())
  role       String   @default("player") @map("role")
  joinedAt   DateTime @default(now()) @map("joined_at")
  userId     String
  campaignId String

  user     User     @relation("UsersCampaigns", fields: [userId], references: [id])
  campaign Campaign @relation("CampaignMembership", fields: [campaignId], references: [id])

  @@unique([userId, campaignId])
  @@map("campaign_members")
}

model CampaignInvite {
  id         String   @id @default(uuid())
  token      String   @unique
  email      String?
  campaignId String
  status     String   @default("pending") // pending, accepted, rejected
  createdAt  DateTime @default(now()) @map("created_at")
  expiresAt  DateTime @map("expires_at")
  campaign   Campaign @relation("CampaignInvites", fields: [campaignId], references: [id])

  @@map("campaign_invites")
}

model Character {
  id             String   @id @default(uuid())
  name           String
  type           String // player, npc,monster
  level          Int      @default(1)
  race           String
  characterClass String   @map("character_class")
  campaignId     String
  userId         String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation("UserCharacters", fields: [userId], references: [id])
  campaign       Campaign @relation("CampaignCharacters", fields: [campaignId], references: [id])

  @@map("characters")
}
